<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI와 함께하는 나만의 수업 만들기</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600;800&display=swap');
        body { font-family: 'Pretendard', sans-serif; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .modal { display: none; }
        .modal.active { display: flex; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <!-- Navigation -->
    <nav class="bg-white border-b sticky top-0 z-10 shadow-sm">
        <div class="max-w-6xl mx-auto px-4">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center space-x-6">
                    <a href="index.html" class="flex items-center text-gray-600 hover:text-blue-600 transition-colors font-bold text-sm">
                        <i class="fa-solid fa-house mr-1"></i> 홈
                    </a>
                    <div class="flex items-center space-x-2 cursor-pointer border-l pl-6" onclick="showTab('intro')">
                        <i class="fa-solid fa-book-open text-blue-600 text-2xl"></i>
                        <span class="font-black text-xl tracking-tight">AI EDU DESIGN</span>
                    </div>
                </div>
                <div class="hidden md:flex space-x-8 h-full">
                    <button onclick="showTab('intro')" class="nav-btn text-sm font-semibold text-blue-600 border-b-2 border-blue-600 px-2" data-tab="intro">개요</button>
                    <button onclick="showTab('quiz')" class="nav-btn text-sm font-semibold text-gray-500 hover:text-blue-500 px-2" data-tab="quiz">리터러시 퀴즈</button>
                    <button onclick="showTab('chat')" class="nav-btn text-sm font-semibold text-gray-500 hover:text-blue-500 px-2" data-tab="chat">AI 수업 설계</button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-4 py-12">
        
        <!-- Intro Tab -->
        <div id="intro" class="tab-content active space-y-6 animate-in fade-in">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white p-8 rounded-2xl shadow-lg relative overflow-hidden">
                <div class="relative z-10">
                    <h2 class="text-3xl font-bold mb-4">AI와 함께하는 나만의 수업 만들기</h2>
                    <p class="text-lg opacity-90 leading-relaxed max-w-2xl">
                        부산대학교 AI융합교육원과 함께하는 교실 혁명! 
                        단순 지식 전달에서 벗어나 '교육 디자이너'로서 AI를 활용하는 방법을 알아봅시다.
                    </p>
                    <div class="mt-6 flex flex-wrap gap-4">
                        <button onclick="showTab('quiz')" class="bg-white text-blue-700 px-6 py-2 rounded-full font-bold flex items-center hover:bg-blue-50 transition-colors shadow-md">
                            학습 시작하기 <i class="fa-solid fa-arrow-right ml-2 text-xs"></i>
                        </button>
                        <button onclick="toggleModal(true)" class="bg-blue-500/30 backdrop-blur-md border border-white/30 text-white px-6 py-2 rounded-full font-bold flex items-center hover:bg-blue-500/50 transition-colors shadow-md">
                            <i class="fa-solid fa-image mr-2 text-xs"></i> 인포그래픽 보기
                        </button>
                    </div>
                </div>
                <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
            </div>
            
            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
                    <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center mb-4 text-xl">
                        <i class="fa-solid fa-microchip"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2">교사의 변화</h3>
                    <p class="text-gray-600">반복적 업무 자동화, 수업 설계 주도권 확보, 개별 맞춤형 피드백 제공.</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
                    <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-lg flex items-center justify-center mb-4 text-xl">
                        <i class="fa-solid fa-user-graduate"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2">학생의 변화</h3>
                    <p class="text-gray-600">사고 확장용 학습, 과정 중심 탐구, 비판적·논리적 사고력 배양.</p>
                </div>
            </div>
        </div>

        <!-- Quiz Tab -->
        <div id="quiz" class="tab-content max-w-2xl mx-auto space-y-6">
            <div id="quiz-container" class="bg-white p-8 rounded-2xl shadow-md border border-gray-100">
                <div class="flex justify-between items-center mb-6">
                    <span class="text-sm font-semibold text-blue-600 uppercase tracking-wider">AI 리터러시 테스트</span>
                    <span id="quiz-progress" class="text-gray-400">1 / 3</span>
                </div>
                <h3 id="quiz-question" class="text-2xl font-bold mb-8">질문이 여기에 표시됩니다.</h3>
                <div id="quiz-options" class="space-y-3">
                    <!-- 버튼들이 동적으로 생성됨 -->
                </div>
            </div>
            
            <div id="quiz-result" class="hidden bg-white p-10 rounded-2xl shadow-md border border-gray-100 text-center">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 text-green-600 rounded-full mb-6 text-3xl">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <h3 class="text-3xl font-bold mb-2">학습 완료!</h3>
                <p id="final-score" class="text-gray-500 mb-6">점수: 0 / 3</p>
                <div class="bg-gray-50 p-6 rounded-xl text-left mb-8">
                    <h4 class="font-bold mb-2 flex items-center text-amber-600"><i class="fa-solid fa-triangle-exclamation mr-2"></i> 기억하세요!</h4>
                    <ul class="text-sm text-gray-600 space-y-2">
                        <li>• AI는 항상 정답만 말하지 않습니다 (환각 주의).</li>
                        <li>• 데이터의 사회적 편향성을 비판적으로 검토해야 합니다.</li>
                        <li>• AI에 의존하기보다 '생각하는 힘'을 길러야 합니다.</li>
                    </ul>
                </div>
                <button onclick="showTab('chat')" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-700 transition-colors">
                    AI 조교와 수업 설계하기
                </button>
            </div>
        </div>

        <!-- Chat Tab -->
        <div id="chat" class="tab-content h-[600px] flex flex-col bg-white rounded-2xl shadow-md border border-gray-100 overflow-hidden">
            <div class="p-4 border-b bg-gray-50 flex items-center justify-between">
                <div class="flex items-center space-x-2">
                    <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
                    <span class="font-bold text-gray-700">AI 수업 설계 조교</span>
                </div>
                <button onclick="resetChat()" class="text-gray-400 hover:text-gray-600">
                    <i class="fa-solid fa-rotate"></i>
                </button>
            </div>
            
            <div id="chat-messages" class="flex-1 overflow-y-auto p-6 space-y-4">
                <!-- 메시지 영역 -->
                <div class="flex justify-start">
                    <div class="max-w-[80%] p-4 rounded-2xl bg-gray-100 text-gray-800 rounded-tl-none text-sm md:text-base">
                        안녕하세요! AI 수업 조교입니다. 오늘 어떤 수업을 설계해볼까요?
                    </div>
                </div>
            </div>

            <div class="p-4 border-t bg-white">
                <div class="flex items-center space-x-2 bg-gray-50 p-2 rounded-xl border border-gray-200 focus-within:ring-2 focus-within:ring-blue-400 transition-all">
                    <input 
                        type="text" id="chat-input"
                        placeholder="AI에게 수업 아이디어나 질문을 입력하세요..."
                        class="flex-1 bg-transparent border-none focus:ring-0 text-sm px-2 outline-none"
                    >
                    <button onclick="sendMessage()" class="bg-blue-600 text-white p-2 rounded-lg hover:bg-blue-700 transition-colors">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
                <p class="text-[10px] text-gray-400 mt-2 text-center">
                    * 이 채팅은 예시용 시뮬레이션입니다. 실제 AI 답변은 다를 수 있습니다.
                </p>
            </div>
        </div>

    </main>

    <!-- Modal Popup -->
    <div id="info-modal" class="modal fixed inset-0 z-50 items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
        <div class="relative bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
            <div class="flex items-center justify-between p-4 border-b">
                <h3 class="font-bold text-lg text-gray-800">수업 설계 인포그래픽</h3>
                <button onclick="toggleModal(false)" class="p-2 hover:bg-gray-100 rounded-full transition-colors">
                    <i class="fa-solid fa-xmark text-xl text-gray-500"></i>
                </button>
            </div>
            <div class="p-2 overflow-auto bg-gray-50 flex justify-center items-center min-h-[400px]">
                <img src="04.PNG" alt="수업 설계 인포그래픽" class="max-w-full h-auto rounded-lg shadow-sm" onerror="this.onerror=null; this.src='https://via.placeholder.com/800x600?text=04.PNG+Not+Found';">
            </div>
            <div class="p-4 bg-white border-t text-center">
                <button onclick="toggleModal(false)" class="bg-gray-800 text-white px-6 py-2 rounded-lg font-semibold hover:bg-gray-900 transition-colors">닫기</button>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="py-8 bg-slate-100 border-t border-slate-200">
        <div class="max-w-4xl mx-auto px-4 text-center">
            <p class="text-slate-500 text-sm">© 2024 AI와 함께하는 나만의 수업 만들기 | PNU AI융합교육원</p>
        </div>
    </footer>

    <script>
        // 탭 전환 로직
        function showTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });
            document.getElementById(tabId).classList.add('active');

            // 내비게이션 스타일 업데이트
            document.querySelectorAll('.nav-btn').forEach(btn => {
                if(btn.getAttribute('data-tab') === tabId) {
                    btn.classList.add('text-blue-600', 'border-b-2', 'border-blue-600');
                    btn.classList.remove('text-gray-500');
                } else {
                    btn.classList.remove('text-blue-600', 'border-b-2', 'border-blue-600');
                    btn.classList.add('text-gray-500');
                }
            });

            if(tabId === 'quiz') resetQuiz();
        }

        // 모달 제어
        function toggleModal(show) {
            const modal = document.getElementById('info-modal');
            if(show) modal.classList.add('active');
            else modal.classList.remove('active');
        }

        // 퀴즈 로직
        const quizData = [
            {
                q: "AI가 그럴듯하게 들리지만 사실이 아닌 정보를 생성하는 현상을 무엇이라고 하나요?",
                a: ["데이터 편향성", "환각 (Hallucination)", "딥러닝", "머신러닝"],
                correct: 1
            },
            {
                q: "AI를 활용한 수업에서 가장 중요한 교사의 역할은 무엇일까요?",
                a: ["단순 지식 전달", "AI 사용 금지", "비판적 사고 및 교육 디자이너", "행정 업무만 담당"],
                correct: 2
            },
            {
                q: "AI가 학습한 데이터에 포함된 사회적 편견을 반영하는 현상은?",
                a: ["데이터 편향성 (Bias)", "최신 정보 반영", "정보의 익명성", "알고리즘 최적화"],
                correct: 0
            }
        ];

        let currentQuiz = 0;
        let score = 0;

        function resetQuiz() {
            currentQuiz = 0;
            score = 0;
            document.getElementById('quiz-container').classList.remove('hidden');
            document.getElementById('quiz-result').classList.add('hidden');
            renderQuiz();
        }

        function renderQuiz() {
            const data = quizData[currentQuiz];
            document.getElementById('quiz-progress').innerText = `${currentQuiz + 1} / ${quizData.length}`;
            document.getElementById('quiz-question').innerText = data.q;
            
            const optionsBox = document.getElementById('quiz-options');
            optionsBox.innerHTML = '';
            data.a.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-4 rounded-xl border-2 border-gray-100 hover:border-blue-500 hover:bg-blue-50 transition-all font-medium flex justify-between items-center group";
                btn.innerHTML = `${opt} <i class="fa-solid fa-chevron-right text-xs opacity-0 group-hover:opacity-100 transition-opacity"></i>`;
                btn.onclick = () => handleAnswer(idx);
                optionsBox.appendChild(btn);
            });
        }

        function handleAnswer(idx) {
            if(idx === quizData[currentQuiz].correct) score++;
            
            currentQuiz++;
            if(currentQuiz < quizData.length) {
                renderQuiz();
            } else {
                document.getElementById('quiz-container').classList.add('hidden');
                document.getElementById('quiz-result').classList.remove('hidden');
                document.getElementById('final-score').innerText = `점수: ${score} / ${quizData.length}`;
            }
        }

        // 채팅 로직
        const chatInput = document.getElementById('chat-input');
        const chatMessages = document.getElementById('chat-messages');

        function sendMessage() {
            const text = chatInput.value.trim();
            if(!text) return;

            // 사용자 메시지 추가
            addMessage(text, 'user');
            chatInput.value = '';

            // 타이핑 인디케이터 시뮬레이션
            const typingDiv = document.createElement('div');
            typingDiv.className = "flex justify-start typing-indicator";
            typingDiv.innerHTML = `<div class="bg-gray-100 p-4 rounded-2xl rounded-tl-none flex space-x-1"><div class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"></div><div class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.1s"></div><div class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div></div>`;
            chatMessages.appendChild(typingDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;

            setTimeout(() => {
                typingDiv.remove();
                const responses = [
                    "좋은 아이디어네요! 그 수업 주제에 맞는 학생 활동지를 만들어드릴까요?",
                    "AI 리터러시 교육을 위해 해당 내용을 비판적으로 검토하는 토론 활동을 추가하면 어떨까요?",
                    "수준별 맞춤형 문제를 생성해 드릴 수 있습니다. 난이도를 어떻게 조절할까요?",
                    "AI의 환각 현상을 주의하면서, 학생들과 함께 사실 확인(Fact-check) 단계를 넣어보세요."
                ];
                addMessage(responses[Math.floor(Math.random() * responses.length)], 'assistant');
            }, 1000);
        }

        function addMessage(text, role) {
            const div = document.createElement('div');
            div.className = `flex ${role === 'user' ? 'justify-end' : 'justify-start'}`;
            const bubble = document.createElement('div');
            bubble.className = `max-w-[80%] p-4 rounded-2xl text-sm md:text-base ${role === 'user' ? 'bg-blue-600 text-white rounded-tr-none' : 'bg-gray-100 text-gray-800 rounded-tl-none'}`;
            bubble.innerText = text;
            div.appendChild(bubble);
            chatMessages.appendChild(div);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function resetChat() {
            chatMessages.innerHTML = '';
            addMessage('초기화되었습니다. 무엇을 도와드릴까요?', 'assistant');
        }

        // 엔터키 처리
        chatInput.addEventListener('keypress', (e) => {
            if(e.key === 'Enter') sendMessage();
        });
    </script>
</body>
</html>
